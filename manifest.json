  "required_packages": [
    "pgs_runtime",
    "pgs_capabilities",
    "pgs_blockchain",
    "pgs_ai_governance"
  ],

  "workspace_outputs": [
    "protocol_snapshot/",
    "tokenized_snapshot/",
    "evidence_snapshot/",
    "vocabulary_snapshot/",
    "trust_snapshot/",
    "traces/"
  ],

  "seed_data": [
    "seeds/license_facts.json",
    "seeds/register_actor_unverified_payload.json"
  ]
}